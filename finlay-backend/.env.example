# =============================================
# Finlay Backend - Environment Variables
# =============================================
# Copy this file as .env and fill in your real keys.

# --- LLM Provider ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# --- Hindsight Memory ---
HINDSIGHT_API_KEY=your_hindsight_api_key_here
HINDSIGHT_PROJECT_ID=finlay-qbit

# --- Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- App ---
APP_ENV=development
